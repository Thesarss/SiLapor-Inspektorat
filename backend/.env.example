# Database
DATABASE_URL=postgresql://user:password@localhost:5432/evaluation_reporting

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
EMAIL_FROM=noreply@example.com

# Server
PORT=3000
NODE_ENV=development

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# Development
DEV_PASSWORD=DevSecure2024!@#

# Security
API_KEY=your-api-key-here
